# LLM Provider
# Options: cli (uses local Claude Code session), anthropic, google, agy
LLM_PROVIDER=cli

# API key — required when LLM_PROVIDER is anthropic or google; unused for cli
MODEL_API_KEY=

# ChromaDB
CHROMA_PERSIST_DIR=.chroma

# Doc Agent
DOCS_DIR=docs
CHUNK_SIZE=500
CHUNK_OVERLAP=50
AGENT_DEBUG=true
AGENT_JUDGE=true

# Multilingual
LANGUAGE=en
# Options: en, de

# Webhook
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=9010
